<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acgist.duckdb.dao.mapper.UserMapper">

    <resultMap id="User" type="com.acgist.duckdb.data.entity.User">
        <id column="id" property="id" />
        <result column="name" property="name" />
    </resultMap>
    
    <resultMap id="UserDto" type="com.acgist.duckdb.data.dto.UserDto" extends="User">
    </resultMap>
    
    <select id="selectAll" resultMap="User">
    select * from t_user
    </select>
    
    <delete id="deleteById">
    delete from t_user where id in
    <foreach collection="id" item="value" open="(" close=")" separator=",">#{value}</foreach>
    </delete>
    
</mapper>
